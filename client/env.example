# 認可サーバー（Go アプリ）のベース URL
OAUTH_ISSUER=http://localhost:8080

OAUTH_CLIENT_ID=oauth2_demo_client
OAUTH_CLIENT_SECRET=demo_client_secret_12345

# init.sql の oauth_clients.redirect_uris と完全一致させる
OAUTH_REDIRECT_URI=http://localhost:3000/callback

# リソースサーバー（backend、既定 :9090）。Next の /api/resource/me がここへプロキシする
RESOURCE_SERVER_URL=http://localhost:9090
